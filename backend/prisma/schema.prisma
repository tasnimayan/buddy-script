generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

// -----------------------------
// Enums
// -----------------------------

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

enum Visibility {
  public
  private
}

enum MediaType {
  image
  video
}

enum Gender {
  Male
  Female
}

// -----------------------------
// Models
// -----------------------------

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.Citext
  passwordHash String     @map("password_hash") // bcrypt
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  profile      Profile?
  authSessions AuthSession[]
  posts        Post[]
  comments     Comment[]
  postLikes    PostLike[]
  commentLikes CommentLike[]

  @@map("users")
}

model Profile {
  userId          String   @id @map("user_id") @db.Uuid
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  avatarMediaKey  String?  @map("avatar_media_key") @db.VarChar(512) // object storage key, nullable
  bio             String?  @db.VarChar(500)
  dob             DateTime? @db.Date
  gender          Gender
  location        String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model AuthSession {
  id               BigInt    @id
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash") @db.VarChar(255) // SHA-256 of opaque token
  userAgent        String?   @map("user_agent") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.Inet
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user")
  @@map("auth_sessions")
}

model Post {
  id           BigInt     @id
  authorId     String     @map("author_id") @db.Uuid
  content      String?    // nullable if media-only post
  visibility   Visibility @default(public)
  mediaCount   Int        @default(0) @map("media_count") // denormalized, avoids a join to know "has media"
  likeCount    BigInt     @default(0) @map("like_count")
  commentCount BigInt     @default(0) @map("comment_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  author   User        @relation(fields: [authorId], references: [id])
  media    PostMedia[]
  comments Comment[]
  likes    PostLike[]

  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "idx_posts_public_feed")
  @@index([authorId, createdAt(sort: Desc)], map: "idx_posts_by_author")
  @@map("posts")
}

model PostMedia {
  id         BigInt    @id
  postId     BigInt    @map("post_id")
  storageKey String    @map("storage_key") @db.VarChar(512) // object storage key, NOT a URL
  mediaType  MediaType @map("media_type")
  extension  String    @db.VarChar(10)
  byteSize   BigInt    @map("byte_size")
  position   Int       @default(0) // display order within the post
  createdAt  DateTime  @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, position]) // prevents ordering collisions
  @@index([postId], map: "idx_post_media_order")
  @@map("post_media")
}

model Comment {
  id               BigInt    @id
  postId           BigInt    @map("post_id")
  authorId         String    @map("author_id") @db.Uuid // corrected from BIGINT -> Uuid to match users.id
  parentCommentId  BigInt?   @map("parent_comment_id") // NULL = top-level comment
  content          String?   // nullable if image-only comment
  mediaKey         String?   @map("media_key") @db.VarChar(512) // single optional image, storage key
  likeCount        BigInt    @default(0) @map("like_count")
  replyCount       BigInt    @default(0) @map("reply_count") // meaningful on top-level comments only
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  post          Post      @relation(fields: [postId], references: [id])
  author        User      @relation(fields: [authorId], references: [id])
  parentComment Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies       Comment[] @relation("CommentReplies")
  likes         CommentLike[]


  @@index([postId, createdAt, id], map: "idx_comments_toplevel") // WHERE parent_comment_id IS NULL in DDL (partial)
  @@index([parentCommentId, createdAt, id], map: "idx_comments_replies")
  @@map("comments")
}

model PostLike {
  postId    BigInt   @map("post_id")
  userId    String   @map("user_id") @db.Uuid // corrected from BIGINT -> Uuid to match users.id
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([postId, userId])
  @@index([postId, createdAt(sort: Desc)], map: "idx_post_likes_recent")
  @@map("post_likes")
}

model CommentLike {
  commentId BigInt   @map("comment_id")
  userId    String   @map("user_id") @db.Uuid // corrected from BIGINT -> Uuid to match users.id
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@id([commentId, userId])
  @@index([commentId, createdAt(sort: Desc)], map: "idx_comment_likes_recent")
  @@map("comment_likes")
}
